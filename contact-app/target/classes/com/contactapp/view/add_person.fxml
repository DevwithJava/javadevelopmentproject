<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.contactapp.controller.AddPersonController"
      spacing="0"
      prefWidth="480"
      style="-fx-background-color: #f4f6f8;">

    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #2c3e50; -fx-padding: 16 20 16 20;">
        <Label text="Add New Contact"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
    </HBox>

    <VBox spacing="14" VBox.vgrow="ALWAYS"
          style="-fx-padding: 20 24 10 24;">

        <Label fx:id="errorLabel"
               wrapText="true"
               maxWidth="Infinity"
               style="-fx-text-fill: #e74c3c; -fx-background-color: #fdecea;
                      -fx-background-radius: 4; -fx-border-color: #e74c3c;
                      -fx-border-radius: 4; -fx-border-width: 1; -fx-padding: 6 10;"/>

        <HBox spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="First Name *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="firstnameField" promptText="e.g. John" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Last Name *" style="-fx-font-weight: bold;"/>
                <TextField fx:id="lastnameField" promptText="e.g. Doe" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <VBox spacing="4">
            <Label text="Nickname *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="nicknameField" promptText="e.g. Johnny" maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Phone Number" style="-fx-font-weight: bold;"/>
                <TextField fx:id="phoneField" promptText="e.g. +33 6 12 34 56 78" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Birth Date" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="birthDatePicker" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <VBox spacing="4">
            <Label text="Email Address" style="-fx-font-weight: bold;"/>
            <TextField fx:id="emailField" promptText="e.g. john@example.com" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Address" style="-fx-font-weight: bold;"/>
            <TextField fx:id="addressField" promptText="e.g. 1 Main Street" maxWidth="Infinity"/>
        </VBox>

        <Label text="* Required fields"
               style="-fx-text-fill: #95a5a6; -fx-font-size: 11px; -fx-font-style: italic;"/>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="10"
          style="-fx-background-color: #dfe6e9; -fx-border-color: #bdc3c7;
                 -fx-border-width: 1 0 0 0; -fx-padding: 16 20 16 20;">
        <Button text="Cancel" onAction="#onCancel"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;"/>
        <Button text="Save Contact" onAction="#onSave" defaultButton="true"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;"/>
    </HBox>

</VBox>