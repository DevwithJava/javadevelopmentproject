<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    main.fxml - Main window layout
    TASK 2
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
           stylesheets="@../css/style.css"
            fx:controller="com.contactapp.controller.MainController"
            prefWidth="1100" prefHeight="650"
            style="-fx-background-color: #f7f9fb;">

   <top>
    <VBox>
        <VBox styleClass="header-box">
            <Label text="📋  Contact App" styleClass="header-title"/>
            <Label text="Manage your contacts" styleClass="header-subtitle"/>
        </VBox>
        <HBox styleClass="toolbar-box" spacing="8">
            <Button text=" Add"    onAction="#onAddContact"    styleClass="btn-add"/>
            <Button text=" Edit"   onAction="#onEditContact"   styleClass="btn-edit"/>
            <Button text=" Delete" onAction="#onDeleteContact" styleClass="btn-delete"/>
            <Button text="↩︎ Refresh" onAction="#onRefresh" styleClass="btn-refresh"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="🔍  Search by name..."
                       onKeyReleased="#onSearch" styleClass="search-field"/>
        </HBox>
    </VBox>
</top>

    <center>
        <TableView fx:id="personTable"
                   style="-fx-background-insets: 0; -fx-padding: 12;">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                <TableColumn fx:id="lastnameColumn" text="Last Name" prefWidth="140"/>
                <TableColumn fx:id="firstnameColumn" text="First Name" prefWidth="140"/>
                <TableColumn fx:id="nicknameColumn" text="Nickname" prefWidth="120"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
                <TableColumn fx:id="addressColumn" text="Address" prefWidth="220"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="220"/>
                <TableColumn fx:id="birthDateColumn" text="D0B" prefWidth="120"/>
            </columns>
        </TableView>
    </center>

</BorderPane>
